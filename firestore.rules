rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isValidFavoritesList(favorites) {
      // Must be a list and capped at a maximum size to prevent Resource Exhaustion / DoS attacks
      return favorites is list && favorites.size() <= 500;
    }

    function isValidUserDoc() {
      let data = request.resource.data;
      // Strict Schema: Ensure no unexpected fields can be injected
      return data.keys().hasOnly(['favorites']) &&
             (!('favorites' in data) || isValidFavoritesList(data.favorites));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // The `deals` collection is dead: live deal data comes from the
    // Supabase-backed FastAPI (api.py), not Firestore — FirestoreDealRepository
    // and its dev-only seeder had zero real callers and were deleted. No
    // match block here means the default-deny rule below covers it; if this
    // collection is ever wired back up, add a scoped rule then rather than
    // reopening public write access to it now for no functional benefit.

    match /users/{userId} {
      // A user can only read, write, and modify their own document
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isEmailVerified() && isValidUserDoc();
      allow delete: if isOwner(userId);

      // Price-alert configs — created, updated, or deleted by the owner
      match /alert_configs/{configId} {
        allow read, create, update, delete: if isOwner(userId) && isEmailVerified();
      }
    }
  }
}