# Awin credentials — required
# Get your API token from: Awin UI → Account → API credentials
AWIN_API_TOKEN=your_oauth2_bearer_token_here
AWIN_PUBLISHER_ID=your_publisher_id_here

# Awin product data feed URLs — optional but recommended
# Provides real product prices; without this, only the Promotions API
# is used and price fields will be zero (sentinels).
#
# How to get feed URLs:
#   1. Log into Awin → Reports → Product Feeds
#   2. Find the merchant's feed → click "Download"
#   3. Copy the full URL (it already includes your API key and feed ID)
#
# Separate multiple URLs with commas. Line-continuation with backslash
# is supported in most shells but NOT in Firebase secret manager —
# paste all URLs on one line there.
#
# Example:
# AWIN_FEED_URLS=https://productdata.awin.com/datafeed/download/apikey/YOUR_KEY/language/en/fid/12345/...,https://productdata.awin.com/datafeed/download/apikey/YOUR_KEY/language/en/fid/67890/...
AWIN_FEED_URLS=
